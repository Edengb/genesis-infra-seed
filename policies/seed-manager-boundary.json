{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBaselineReadOnlyAndScopedWrites",
      "Effect": "Allow",
      "Action": [
        "iam:Get*",
        "iam:List*",
        "s3:Get*",
        "s3:ListAllMyBuckets", 
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:UpdateRole",
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:SetDefaultPolicyVersion",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:UpdateAssumeRolePolicy",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:TagPolicy",
        "iam:UntagPolicy",
        "s3:ListBucket",
        "s3:PutObject",
        "s3:DeleteObject",
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret",
        "sts:GetCallerIdentity",
        "sts:AssumeRoleWithWebIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowPassRoleOnlyForInfraseedRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::${aws_account_id}:role/genesis-*"
    },
    {
      "Sid": "DenyCreateRoleWithoutBoundary",
      "Effect": "Deny",
      "Action": [
        "iam:CreateRole",
        "iam:CreateUser"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "iam:PermissionsBoundary": [
            "arn:aws:iam::${aws_account_id}:policy/genesis-seed-manager-boundary"
          ]
        }
      }
    },
    {
      "Sid": "DenyRemovingBoundaryFromExistingPrincipals",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteRolePermissionsBoundary",
        "iam:DeleteUserPermissionsBoundary"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyMutatingBoundaryPolicyItself",
      "Effect": "Deny",
      "Action": [
        "iam:DeletePolicy",
        "iam:DeletePolicyVersion",
        "iam:CreatePolicyVersion",
        "iam:SetDefaultPolicyVersion"
      ],
      "Resource": [
        "arn:aws:iam::${aws_account_id}:policy/genesis-seed-manager-boundary"
      ]
    },
    {
      "Sid": "DenyMutatingTheOIDCProvider",
      "Effect": "Deny",
      "Action": [
        "iam:DeleteOpenIDConnectProvider",
        "iam:UpdateOpenIDConnectProviderThumbprint",
        "iam:AddClientIDToOpenIDConnectProvider",
        "iam:RemoveClientIDFromOpenIDConnectProvider"
      ],
      "Resource": "arn:aws:iam::${aws_account_id}:oidc-provider/token.actions.githubusercontent.com"
    },
    {
      "Sid": "DenyMutatingTheStateBucket",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteBucket",
        "s3:PutBucketVersioning",
        "s3:PutBucketPolicy",
        "s3:DeleteBucketPolicy",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutEncryptionConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::genesis-tfstate-${aws_account_id}-${aws_region}",
        "arn:aws:s3:::genesis-tfstate-${aws_account_id}-${aws_region}/*"
      ]
    },
    {
      "Sid": "DenyWildcardIAMWithoutBoundaryCondition",
      "Effect": "Deny",
      "Action": [
        "iam:PutUserPolicy",
        "iam:AttachUserPolicy"
      ],
      "Resource": "*"
    }
  ]
}
